    printf '%s%s%s\n' "$BOLD" "mihomo4asus" "$RESET"
    printf '\n'
    print_message "ACTION" "Service commands"
    printf '  mihomo install       install script, core and boot hooks\n'
    printf '  mihomo start         start Mihomo and apply routing rules\n'
    printf '  mihomo stop          stop Mihomo and remove routing rules\n'
    printf '  mihomo restart       restart Mihomo\n'
    printf '  mihomo status        show core state and architecture\n'
    printf '  mihomo logs          follow Mihomo core log until Ctrl+C\n'
    printf '  mihomo update        update Mihomo core if a new version exists\n'
    printf '  mihomo subscription  show/set/update subscription config URL\n'
    printf '\n'
    print_message "ACTION" "Routing lists"
    printf '  mihomo setup         interactive include/exclude setup\n'
    printf '  mihomo include show|add|del|set|clear [ip-or-cidr...]\n'
    printf '  mihomo exclude show|add|del|set|clear [ip-or-cidr...]\n'
    printf '\n'
    print_message "ACTION" "Subscription config"
    printf '  mihomo subscription show\n'
    printf '  mihomo subscription set <url> [hours]\n'
    printf '  mihomo subscription hours <hours>\n'
    printf '  mihomo subscription resolve <internal-ip|clear>\n'
    printf '  mihomo subscription update\n'
    printf '  mihomo subscription clear\n'
    printf '\n'
    print_message "ACTION" "Maintenance"
    printf '  mihomo uninstall     remove core, files, hooks and iptables rules\n'
}

subscription_setup_menu() {
    ensure_dirs
    while :; do
        printf '\n%s%s%s\n' "$BOLD" "Mihomo subscription setup" "$RESET"
        subscription_mihomo show
        printf '\n'
        printf '  1) Set URL and update interval\n'
        printf '  2) Change update interval\n'
        printf '  3) Update now\n'
        printf '  4) Set host override IP\n'
        printf '  5) Clear host override IP\n'
        printf '  6) Disable subscription\n'
        printf '  0) Back\n'
        printf '\nSelect option: '
        read choice
        case "$choice" in
            1)
                printf 'Enter subscription URL: '
                read url
                printf 'Update interval in hours [24]: '
                read hours
                [ -n "$hours" ] || hours=24
                subscription_mihomo set "$url" "$hours"
                pause_enter
                ;;
            2)
                printf 'Update interval in hours: '
                read hours
                subscription_mihomo hours "$hours"
                pause_enter
                ;;
            3) subscription_mihomo update; pause_enter ;;
            4)
                printf 'Enter internal subscription server IP: '
                read resolve_ip
                subscription_mihomo resolve "$resolve_ip"
                pause_enter
                ;;
            5) subscription_mihomo resolve clear; pause_enter ;;
            6) subscription_mihomo clear; pause_enter ;;
            0) return 0 ;;
            *) print_message "WARN" "unknown option" ;;
        esac
    done
}

main_menu() {
    while :; do
        printf '\n%s%s%s\n' "$BOLD" "mihomo4asus" "$RESET"
        printf '  1) Status\n'
        printf '  2) Start\n'
        printf '  3) Stop\n'
        printf '  4) Restart\n'
        printf '  5) Update core\n'
        printf '  6) Subscription setup\n'
        printf '  7) Routing setup\n'
        printf '  8) Show core log\n'
        printf '  9) Show commands\n'
        printf '  0) Exit\n'
        printf '\nSelect option: '
        read choice
        case "$choice" in
            1) status_mihomo; pause_enter ;;
            2) start_mihomo; pause_enter ;;
            3) stop_mihomo; pause_enter ;;
            4) stop_mihomo; sleep 2; start_mihomo; pause_enter ;;
            5) update_mihomo; pause_enter ;;
            6) subscription_setup_menu ;;
            7) setup_mihomo ;;
            8) log_mihomo ;;
            9) usage_mihomo; pause_enter ;;
            0) exit 0 ;;
            *) print_message "WARN" "unknown option" ;;
        esac
    done
}

uninstall_mihomo() {
    stop_mihomo
    stop_log_guard
    rm -rf "$MIHOMO_HOME"
    rm -f "$SCRIPT_PATH" "$LN_PATH"
    [ -f /jffs/configs/profile.add ] && sed -i "/alias mihomo=.*mihomo/d" /jffs/configs/profile.add
    rmdir "$(dirname "$SCRIPT_PATH")" 2>/dev/null
    log "mihomo uninstalled"
}

case "$1" in
    "") main_menu ;;
    install) install_mihomo ;;
    start) start_mihomo ;;
    stop) stop_mihomo ;;
    restart) stop_mihomo; sleep 2; start_mihomo ;;
    status) status_mihomo ;;
    log|logs) log_mihomo ;;
    update) update_mihomo ;;
    subscription|sub) shift; subscription_mihomo "$@" ;;
    setup) setup_mihomo ;;
    exclude) shift; exclude_mihomo "$@" ;;
    include) shift; include_mihomo "$@" ;;
    uninstall) uninstall_mihomo ;;
    apply-rules) apply_rules ;;
    help|-h|--help) usage_mihomo ;;
    *) usage_mihomo; exit 1 ;;
esac
