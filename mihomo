            : > "$INCLUDE_FILE"
            append_list_items "$INCLUDE_FILE" "$@"
            print_message "SUCCESS" "included IP list updated"
            printf '%s\n' "included IP list updated" | logger -t mihomo
            is_running && apply_rules
